{
  "name": "excel-offline-tool-tests",
  "version": "1.0.0",
  "description": "Excel 离线工具完整测试套件",
  "scripts": {
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js unit/ --coverage --coverageDirectory=./reports/coverage",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js integration/",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:debug": "npx playwright test --debug",
    "test:all": "npm run test && npm run test:e2e",
    "test:simple": "node run-tests.js",
    "report": "npx serve reports",
    "playwright:install": "npx playwright install",
    "playwright:install-deps": "npx playwright install-deps"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jszip": "^3.10.1",
    "xlsx": "^0.18.5"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "moduleFileExtensions": [
      "js",
      "json"
    ],
    "transform": {},
    "testMatch": [
      "**/*.test.js"
    ],
    "collectCoverageFrom": [
      "../src/**/*.js",
      "../excel.html"
    ],
    "coverageReporters": [
      "text",
      "html",
      "json"
    ],
    "coverageDirectory": "./reports/coverage"
  }
}
